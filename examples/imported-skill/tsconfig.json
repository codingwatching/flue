{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowArbitraryExtensions": true,
		"allowImportingTsExtensions": true,
		"target": "ES2022",
		"lib": ["ESNext"],
		"strict": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"noEmit": true
	},
	"include": [".flue/**/*.ts"],
	"exclude": ["dist"]
}
